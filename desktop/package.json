{
  "name": "visionstudio",
  "productName": "VisionStudio",
  "version": "0.1.0",
  "description": "LLM-powered specification authoring and evaluation",
  "type": "module",
  "main": "dist-main/index.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "npm run build:main && electron .",
    "build:main": "tsc -p main/tsconfig.json && tsc -p main/tsconfig.preload.json && mv dist-main/preload.js dist-main/preload.cjs",
    "build": "npm run build:main && vite build",
    "start": "electron .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@types/marked": "^5.0.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "marked": "^18.0.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^33.0.0",
    "node-pty": "^1.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
